{
	"extends": "@w0s/tsconfig/bundler",
	"include": ["src/*.user.ts", "@types/*.d.ts"],
	"compilerOptions": {
		/* Type Checking */
		"alwaysStrict": false, // ❌ deprecated in TypeScript 6.0

		/* Modules */
		"rootDir": "src",

		/* Emit */
		"outDir": "dist",

		/* Others */
		"ignoreDeprecations": "6.0"
	}
}
